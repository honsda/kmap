---
import '../styles/global.css';
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}/kmap.svg?v=2`} />
		<meta name="generator" content={Astro.generator} />
		<title>kmap | Kanji Radical Sandbox</title>
		<meta name="title" content="kmap | Kanji Radical Sandbox" />
		<meta name="description" content="An interactive, visual sandbox for exploring Japanese Kanji through their constituent radicals. Combine radicals and discover their evolution." />

		<!-- Open Graph / Facebook -->
		<meta property="og:type" content="website" />
		<meta property="og:url" content="https://honsda.github.io/kmap/" />
		<meta property="og:title" content="kmap | Kanji Radical Sandbox" />
		<meta property="og:description" content="An interactive, visual sandbox for exploring Japanese Kanji through their constituent radicals. Combine radicals and discover their evolution." />

		<!-- Twitter -->
		<meta property="twitter:card" content="summary" />
		<meta property="twitter:url" content="https://honsda.github.io/kmap/" />
		<meta property="twitter:title" content="kmap | Kanji Radical Sandbox" />
		<meta property="twitter:description" content="An interactive, visual sandbox for exploring Japanese Kanji through their constituent radicals. Combine radicals and discover their evolution." />
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700&family=Space+Grotesk:wght@400;500;600;700&display=swap" rel="stylesheet">
		<style>
			:root {
				font-family: 'Plus Jakarta Sans', sans-serif;
			}
			h1, h2, h3, h4, h5, h6 {
				font-family: 'Space Grotesk', sans-serif;
			}
		</style>
	</head>
	<body class="bg-[#121212] text-slate-100 min-h-screen selection:bg-red-650 selection:text-white antialiased overflow-x-hidden">
		<slot />
	</body>
</html>

